---
---

<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" is:inline></script>

<footer class="footer bg-[#FAFAF9] relative overflow-hidden">
  <div class="md:px-12 flex flex-col min-h-[600px] w-full max-w-[1440px] z-10 mr-auto ml-auto pt-24 pr-6 pb-12 pl-6 relative justify-between">
    <!-- Background Image & Gradient Layers -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[100vw] h-full -z-10 pointer-events-none">
      <img src="https://img.freepik.com/free-photo/grungy-gray-marble-textured-background_53876-108405.jpg" class="absolute inset-0 w-full h-full object-cover" alt="Marble Background" aria-hidden="true">
      <div class="absolute inset-0 bg-gradient-to-b from-white/40 to-white/100"></div>
    </div>

    <!-- Top Directory Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 w-full items-start justify-between relative z-10 border-b border-black/10 pb-20">
      <!-- Navigate Section -->
      <div class="flex flex-col gap-6">
        <h4 class="uppercase text-xs font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans flex items-center gap-2">
          <span class="text-[#A50020] text-[8px]">◆</span> Navigate
        </h4>
        <div class="flex flex-col gap-4 font-sans text-sm font-light text-[#4A4744] uppercase tracking-widest">
          <a href="/" class="hover:text-[#A50020] transition-colors w-fit">Home</a>
                    <a href="/pricing" class="hover:text-[#A50020] transition-colors w-fit">Pricing</a>
          <a href="/hydra-standard" class="hover:text-[#A50020] transition-colors w-fit">Our Philosophy</a>
                <a href="/digital-landscape" class="hover:text-[#A50020] transition-colors">How We Design</a>
          <a href="/hydra-link" class="hover:text-[#A50020] transition-colors w-fit">HydraLinks</a>
        </div>
      </div>

      <!-- Connect Info -->
      <div class="flex flex-col gap-6">
        <h4 class="uppercase text-xs font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans flex items-center gap-2">
          <span class="text-[#A50020] text-[8px]">◆</span> Connect
        </h4>
        <div class="flex flex-col gap-4 font-sans text-sm font-light text-[#4A4744]">
          <a href="https://wa.me/YOUR_NUMBER" target="_blank" rel="noopener noreferrer" class="hover:text-[#A50020] transition-colors w-fit uppercase tracking-widest">WhatsApp Direct</a>
          <a href="mailto:support@hydradyna.com" class="hover:text-[#A50020] transition-colors w-fit uppercase tracking-widest">support@hydradyna.com</a>
        </div>
      </div>

      <!-- Social Links -->
      <div class="flex flex-col gap-6">
        <h4 class="uppercase text-xs font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans flex items-center gap-2">
          <span class="text-[#A50020] text-[8px]">◆</span> Social Links
        </h4>
        <div class="flex flex-col gap-4 font-sans text-sm font-light text-[#4A4744] uppercase tracking-widest">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="hover:text-[#A50020] transition-colors w-fit">Instagram</a>
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="hover:text-[#A50020] transition-colors w-fit">Facebook</a>
          <a href="https://x.com" target="_blank" rel="noopener noreferrer" class="hover:text-[#A50020] transition-colors w-fit">X</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="hover:text-[#A50020] transition-colors w-fit">LinkedIn</a>
        </div>
      </div>

      <!-- Company Address -->
      <div class="flex flex-col gap-6">
        <h4 class="uppercase text-xs font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans flex items-center gap-2">
          <span class="text-[#A50020] text-[8px]">◆</span> Headquarters
        </h4>
        <div class="flex flex-col gap-2 font-sans text-sm font-light text-[#4A4744] opacity-80 leading-relaxed uppercase tracking-widest">
          <p class="">Hydra Dynamics Ltd.</p>
          <p class="">Level 35, WTC</p>
          <p>Colombo 01, Sri Lanka</p>
        </div>
      </div>
    </div>

    <!-- Giant Centered Wordmark -->
    <div class="flex mt-20 mb-12 z-10 w-full relative justify-center">
      <h1 class="font-serif text-[#1A1A1A]/5 text-7xl sm:text-9xl md:text-[12rem] lg:text-[15rem] leading-none tracking-tighter font-normal select-none pointer-events-none">
        HydraDyna
      </h1>
    </div>

    <!-- Bottom Copyright -->
    <div class="w-full flex flex-col md:flex-row justify-between items-center gap-4 pt-4 relative z-10">
      <p class="font-sans text-xs font-light text-[#4A4744] tracking-widest uppercase">
        © Hydra Dynamics, 2025
      </p>
      <div class="flex gap-8 font-sans text-xs font-light text-[#4A4744] tracking-widest uppercase">
        <a href="#" class="hover:text-[#A50020] transition-colors">Privacy</a>
        <a href="#" class="hover:text-[#A50020] transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500&display=swap');

  .font-serif { font-family: 'Cormorant Garamond', serif; }
  .font-sans { font-family: 'Outfit', sans-serif; }

  .footer {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }
</style>
