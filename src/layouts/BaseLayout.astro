---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title = 'Hydra Dynamics | Engineering Digital Permanence',
  description = 'Elite-grade engineering without the agency tax.',
  image = 'https://kade.lk/og-image.svg',
  keywords = 'web development, Astro, Next.js, full-stack engineering, digital permanence'
} = Astro.props;

const siteUrl = Astro.site?.origin ?? 'https://kade.lk';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const pageName = title.split('|')[0]?.trim() ?? 'Hydra Dynamics';
const isHomePage = Astro.url.pathname === '/';
const structuredData = [
  {
    '@type': 'ProfessionalService',
    '@id': `${siteUrl}/#business`,
    name: 'Hydra Dynamics',
    alternateName: 'Hydra Dynamics Ltd.',
    url: siteUrl,
    description,
    image,
    logo: `${siteUrl}/favicon.svg`,
    email: 'support@hydradyna.com',
    priceRange: '$$',
    areaServed: {
      '@type': 'Country',
      name: 'Sri Lanka'
    },
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Colombo',
      addressCountry: 'LK'
    },
    knowsAbout: [
      'Astro',
      'Next.js',
      'Web Development',
      'Web Applications',
      'Digital Engineering',
      'AI Automation'
    ]
  },
  {
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    url: siteUrl,
    name: 'Hydra Dynamics',
    description,
    publisher: {
      '@id': `${siteUrl}/#business`
    },
    inLanguage: 'en-US'
  },
  {
    '@type': 'WebPage',
    '@id': `${canonicalURL.href}#webpage`,
    url: canonicalURL.href,
    name: title,
    description,
    isPartOf: {
      '@id': `${siteUrl}/#website`
    },
    about: {
      '@id': `${siteUrl}/#business`
    },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: image
    },
    inLanguage: 'en-US'
  },
  ...(isHomePage
    ? []
    : [
        {
          '@type': 'BreadcrumbList',
          '@id': `${canonicalURL.href}#breadcrumb`,
          itemListElement: [
            {
              '@type': 'ListItem',
              position: 1,
              name: 'Home',
              item: siteUrl
            },
            {
              '@type': 'ListItem',
              position: 2,
              name: pageName,
              item: canonicalURL.href
            }
          ]
        }
      ])
];
---

<html lang="en" class="scroll-smooth scroll-pt-20">
<head>
  <!-- Essential Meta Tags -->
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="keywords" content={keywords}/>
  <link rel="canonical" href={canonicalURL}/>
  <meta name="author" content="Hydra Dynamics"/>
  <meta name="theme-color" content="#A50020"/>
  <meta name="language" content="English"/>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:large"/>

  <!-- Google Search Console Verification -->
  <meta name="google-site-verification" content="YOUR_VERIFICATION_CODE"/>

  <!-- Open Graph Tags (Social Media) -->
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={image}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={canonicalURL}/>
  <meta property="og:site_name" content="Hydra Dynamics"/>
  <meta property="og:locale" content="en_US"/>

  <!-- Twitter Card Tags -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={image}/>
  <meta name="twitter:site" content="@hydradynamics"/>
  <meta name="twitter:creator" content="@hydradynamics"/>

  <!-- Additional SEO Meta Tags -->
  <meta name="revisit-after" content="7 days"/>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": structuredData })}></script>

  <!-- Tailwind CSS & Icon Library -->
  <script src="https://cdn.tailwindcss.com" is:inline></script>
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" is:inline></script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500&display=swap');

    /* Base Typography */
    .font-serif { font-family: 'Cormorant Garamond', serif; }
    .font-sans { font-family: 'Outfit', sans-serif; }

    /* Custom Utilities & Animations */
    ::selection {
        background-color: #A50020;
        color: #F5F4F2;
    }

    .hover-crimson-lift {
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hover-crimson-lift:hover {
        box-shadow: 0 20px 40px -15px rgba(165, 0, 32, 0.2);
        border-color: rgba(165, 0, 32, 0.4);
        transform: translateY(-4px);
    }

    .hover-btn-fill {
        position: relative;
        overflow: hidden;
        z-index: 1;
    }
    .hover-btn-fill::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #A50020;
        z-index: -1;
        clip-path: circle(0% at 50% 120%);
        transition: clip-path 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hover-btn-fill:hover::before {
        clip-path: circle(150% at 50% 120%);
    }
    .hover-btn-fill:hover {
        color: #F5F4F2 !important;
        border-color: #A50020 !important;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-on-load {
        animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    .delay-100 { animation-delay: 100ms; }
    .delay-200 { animation-delay: 200ms; }
    .delay-300 { animation-delay: 300ms; }

    /* Global Background */
    body {
        overflow-x: hidden;
        background-color: #FAFAF9;
        color: #4A4744;
    }
  </style>
</head>
<body class="antialiased overflow-x-hidden text-[#4A4744] font-sans bg-[#FAFAF9]">
  <!-- Marble Texture Overlay (Global) -->
  <div class="fixed inset-0 pointer-events-none z-[-1] opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.015%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');">
  </div>

  <Nav/>
  <main>
    <slot/>
  </main>
  <Footer/>
</body>
</html>
