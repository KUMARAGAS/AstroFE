---
import { getSiteSettings, getBusinessDetails } from '../lib/directus.js';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const site = await getSiteSettings();
const business = await getBusinessDetails();
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL;
const DIRECTUS_TOKEN = import.meta.env.DIRECTUS_TOKEN;

const {
  
  title = site.core_meta_title,
  description = site.core_meta_description,
  ogImage = site.core_og_image
} = Astro.props;

function asset(id: string | null | undefined): string {
  if (!id) return '';
  return `${DIRECTUS_URL}/assets/${id}?access_token=${DIRECTUS_TOKEN}`;
}
---

<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={asset(ogImage)}/>
  <meta property="og:type" content="website"/>
  <link rel="icon" href={asset(site.core_favicon_light)} media="(prefers-color-scheme: light)"/>
  <link rel="icon" href={asset(site.core_favicon_dark)} media="(prefers-color-scheme: dark)"/>
  {site.core_google_search_console_verification && (
    <meta name="google-site-verification" content={site.core_google_search_console_verification}/>
  )}
  {site.core_google_analytics_id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.core_google_analytics_id}`}></script>
      <script define:vars={{ gaId: site.core_google_analytics_id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --gold: #C9A84C;
      --gold-light: #E8C97A;
      --dark: #0A0A0A;
      --dark-2: #111111;
      --dark-3: #1A1A1A;
      --dark-4: #222222;
      --text: #F0EDE8;
      --text-muted: #888880;
    }
    body {
      background: var(--dark);
      color: var(--text);
      font-family: 'Georgia', serif;
    }
    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .label {
      font-size: 12px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 12px;
      display: block;
    }
    .page-hero {
      min-height: 40vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 120px 24px 60px;
      background:
        linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.95)),
        url('/hero-bg.jpg') center/cover no-repeat;
    }
    .page-hero h1 {
      font-size: clamp(36px, 5vw, 64px);
      font-weight: 400;
      margin: 0;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--dark);
      padding: 14px 36px;
      text-decoration: none;
      font-size: 13px;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: background 0.3s;
      display: inline-block;
    }
    .btn-primary:hover { background: var(--gold-light); }
    .btn-secondary {
      border: 1px solid var(--gold);
      color: var(--gold);
      padding: 14px 36px;
      text-decoration: none;
      font-size: 13px;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: all 0.3s;
      display: inline-block;
    }
    .btn-secondary:hover { background: var(--gold); color: var(--dark); }
  </style>
</head>
<body>
  <Nav siteSettings={site}/>
  <main>
    <slot/>
  </main>
  <Footer site={site} business={business}/>
</body>
</html>