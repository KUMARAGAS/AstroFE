---
import { getSiteSettings, getBusinessDetails } from '../lib/directus.js';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const site = await getSiteSettings();
const business = await getBusinessDetails();
const DIRECTUS_URL = import.meta.env.DIRECTUS_URL;
const DIRECTUS_TOKEN = import.meta.env.DIRECTUS_TOKEN;

const {
  
  title = site.core_meta_title,
  description = site.core_meta_description,
  ogImage = site.core_og_image
} = Astro.props;

function asset(id: string | null | undefined): string {
  if (!id) return '';
  return `${DIRECTUS_URL}/assets/${id}?access_token=${DIRECTUS_TOKEN}`;
}
---

<html lang="en" class="scroll-smooth scroll-pt-20">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

   <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description}/>

<!<link rel="canonical" href={canonicalURL}/>/>

   <!-- OG Tags -->
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={asset(ogImage)}/>
  <meta property="og:type" content="website"/>

  <!-- Favicon -->
  <link rel="icon" href={asset(site.core_favicon_light)} media="(prefers-color-scheme: light)"/>
  <link rel="icon" href={asset(site.core_favicon_dark)} media="(prefers-color-scheme: dark)"/>

  <!-- Google Search Console -->
  {site.core_google_search_console_verification && (
    <meta name="google-site-verification" content={site.core_google_search_console_verification}/>
  )}

  <!-- Google Analytics -->
  {site.core_google_analytics_id && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.core_google_analytics_id}`}></script>
      <script define:vars={{ gaId: site.core_google_analytics_id }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>

  )}


<!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": site.core_site_name,
    "description": site.core_meta_description,
    "url": "https://hydradynamics.lk"
  })}/>

  <!-- Tailwind CSS & Icon Library -->
  <script src="https://cdn.tailwindcss.com" is:inline></script>
  <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" is:inline></script>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500&display=swap');

    /* Base Typography */
    .font-serif { font-family: 'Cormorant Garamond', serif; }
    .font-sans { font-family: 'Outfit', sans-serif; }

    /* Custom Utilities & Animations */
    ::selection {
        background-color: #A50020;
        color: #F5F4F2;
    }

    .hover-crimson-lift {
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hover-crimson-lift:hover {
        box-shadow: 0 20px 40px -15px rgba(165, 0, 32, 0.2);
        border-color: rgba(165, 0, 32, 0.4);
        transform: translateY(-4px);
    }

    .hover-btn-fill {
        position: relative;
        overflow: hidden;
        z-index: 1;
    }
    .hover-btn-fill::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #A50020;
        z-index: -1;
        clip-path: circle(0% at 50% 120%);
        transition: clip-path 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .hover-btn-fill:hover::before {
        clip-path: circle(150% at 50% 120%);
    }
    .hover-btn-fill:hover {
        color: #F5F4F2 !important;
        border-color: #A50020 !important;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-on-load {
        animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    .delay-100 { animation-delay: 100ms; }
    .delay-200 { animation-delay: 200ms; }
    .delay-300 { animation-delay: 300ms; }

    /* Global Background */
    body {
        overflow-x: hidden;
        background-color: #FAFAF9;
        color: #4A4744;
    }
  </style>
</head>
<body class="antialiased overflow-x-hidden text-[#4A4744] font-sans bg-[#FAFAF9]">
  <!-- Marble Texture Overlay (Global) -->
  <div class="fixed inset-0 pointer-events-none z-[-1] opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.015%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');">
  </div>

  <Nav siteSettings={site}/>
  <main>
    <slot/>
  </main>
  <Footer site={site} business={business}/>
</body>
</html>