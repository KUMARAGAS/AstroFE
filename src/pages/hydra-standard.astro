    <script>
        document.addEventListener('DOMContentLoaded', function() {

    // --- Mobile Menu ---
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const closeMenuBtn = document.getElementById('close-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    if (!mobileMenu) return;
    const mobileMenuEl = mobileMenu;

    function openMenu() {
        mobileMenuEl.style.display = 'flex';
        requestAnimationFrame(() => { mobileMenuEl.style.opacity = '1'; });
        document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
        mobileMenuEl.style.opacity = '0';
        setTimeout(() => { mobileMenuEl.style.display = 'none'; document.body.style.overflow = ''; }, 300);
    }
    if (hamburgerBtn) hamburgerBtn.addEventListener('click', openMenu);
    if (closeMenuBtn) closeMenuBtn.addEventListener('click', closeMenu);
    mobileLinks.forEach(link => link.addEventListener('click', closeMenu));

    // --- Floating Toggle Visibility ---
    const floatingToggle = document.getElementById('floating-toggle');
    const processSection = document.getElementById('process');
    const contactSection = document.getElementById('contact');

    function updateFloatingToggleVisibility() {
        if (!processSection || !floatingToggle) return;
        const processRect = processSection.getBoundingClientRect();
        const contactRect = contactSection ? contactSection.getBoundingClientRect() : null;
        const showStart = processRect.top < -200;
        const hideAtEnd = contactRect && contactRect.top < window.innerHeight * 0.5;
        if (showStart && !hideAtEnd) {
            floatingToggle.classList.remove('hidden-float');
            floatingToggle.classList.add('visible-float');
        } else {
            floatingToggle.classList.remove('visible-float');
            floatingToggle.classList.add('hidden-float');
        }
    }
    window.addEventListener('scroll', updateFloatingToggleVisibility, { passive: true });
    updateFloatingToggleVisibility();

    // --- Toggle (Website / Web App) ---
    const toggleWebsiteBtn = document.getElementById('toggle-website');
    const toggleWebappBtn = document.getElementById('toggle-webapp');
    const toggleBg = document.getElementById('toggle-bg');
    let currentToggle: 'website' | 'webapp' = 'website';

    function setToggle(mode: 'website' | 'webapp') {
        if (!toggleBg || !toggleWebsiteBtn || !toggleWebappBtn) return;
        if (currentToggle === mode) return;
        currentToggle = mode;
        if (mode === 'website') {
            toggleBg.style.transform = 'translateX(0)';
            toggleWebsiteBtn.style.color = 'white';
            toggleWebappBtn.style.color = 'rgba(255,255,255,0.5)';
        } else {
            toggleBg.style.transform = 'translateX(100%)';
            toggleWebappBtn.style.color = 'white';
            toggleWebsiteBtn.style.color = 'rgba(255,255,255,0.5)';
        }
        // Switch all toggle content groups
        const groups = ['process', 'superiority', 'scalability', 'maintenance'];
        groups.forEach(group => {
            const allInGroup = document.querySelectorAll(`[data-toggle-group="${group}"]`);
            allInGroup.forEach(el => {
                const isWebsite = el.id.includes('website') || el.id === 'content-website';
                const isWebapp  = el.id.includes('webapp')  || el.id === 'content-webapp';
                if (mode === 'website') {
                    if (isWebsite) { el.classList.remove('hidden-toggle'); el.classList.add('visible-toggle'); }
                    if (isWebapp)  { el.classList.remove('visible-toggle'); el.classList.add('hidden-toggle'); }
                } else {
                    if (isWebapp)  { el.classList.remove('hidden-toggle'); el.classList.add('visible-toggle'); }
                    if (isWebsite) { el.classList.remove('visible-toggle'); el.classList.add('hidden-toggle'); }
                }
            });
        });
    }

    if (toggleWebsiteBtn) toggleWebsiteBtn.addEventListener('click', () => setToggle('website'));
    if (toggleWebappBtn)  toggleWebappBtn.addEventListener('click',  () => setToggle('webapp'));

    // --- Accordion ---
    const accordionTriggers = document.querySelectorAll<HTMLElement>('.accordion-trigger');
    accordionTriggers.forEach(trigger => {
        trigger.addEventListener('click', function(this: HTMLElement) {
            const item = this.closest('.accordion-item');
            if (!item) return;
            const content = item.querySelector<HTMLElement>('.accordion-content');
            const chevron = this.querySelector<HTMLElement>('.accordion-chevron');
            const parent = this.closest('[data-accordion]');
            if (!content || !chevron) return;

            if (parent) {
                parent.querySelectorAll('.accordion-item').forEach((sibling: Element) => {
                    if (sibling !== item) {
                        const sibContent = sibling.querySelector<HTMLElement>('.accordion-content');
                        const sibChevron = sibling.querySelector<HTMLElement>('.accordion-chevron');
                        if (sibContent) { sibContent.style.maxHeight = '0'; sibContent.classList.remove('open'); }
                        if (sibChevron) { sibChevron.classList.remove('rotated'); }
                    }
                });
            }

            if (content.classList.contains('open')) {
                content.style.maxHeight = '0';
                content.classList.remove('open');
                chevron.classList.remove('rotated');
            } else {
                content.style.maxHeight = content.scrollHeight + 'px';
                content.classList.add('open');
                chevron.classList.add('rotated');
            }
        });
    });

    // --- Scroll animations ---
    const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const target = entry.target as HTMLElement;
                target.style.opacity = '1';
                target.style.transform = 'translateY(0)';
            }
        });
    }, observerOptions);

    document.querySelectorAll<HTMLElement>('.hover-crimson-lift').forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1), box-shadow 0.4s cubic-bezier(0.16,1,0.3,1), border-color 0.4s cubic-bezier(0.16,1,0.3,1)';
        observer.observe(el);
    });

    // --- Nav shadow on scroll ---
    const nav = document.querySelector<HTMLElement>('nav');
    window.addEventListener('scroll', () => {
        if (!nav) return;
        nav.style.boxShadow = window.scrollY > 100 ? '0 1px 3px rgba(0,0,0,0.05)' : 'none';
    }, { passive: true });

});
    </script>


