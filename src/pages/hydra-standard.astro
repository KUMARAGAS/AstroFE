                <h1 class="font-serif text-[#1A1A1A]/5 text-7xl sm:text-9xl md:text-[12rem] lg:text-[15rem] leading-none tracking-tighter font-normal select-none pointer-events-none">
                    Permanence</h1>
            </div>
            <div class="w-full flex flex-col md:flex-row justify-between items-center gap-4 pt-4 relative z-10">
                <p class="font-sans text-sm font-light text-[#4A4744] tracking-widest uppercase">© Hydra Dynamics, 2025
                </p>
                <div class="flex gap-8 font-sans text-sm font-light text-[#4A4744] tracking-widest uppercase"><a href="#" class="hover:text-[#A50020] transition-colors">Privacy</a><a href="#" class="hover:text-[#A50020] transition-colors">Terms</a></div>
