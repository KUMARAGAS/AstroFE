---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found | Hydra Dynamics" description="Page not found. The page you are looking for does not exist or has been relocated. Return to Hydra Dynamics homepage.">

    <style is:global>
        .hover-btn-fill {
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        .hover-btn-fill::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #A50020;
            z-index: -1;
            clip-path: circle(0% at 50% 120%);
            transition: clip-path 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hover-btn-fill:hover::before {
            clip-path: circle(150% at 50% 120%);
        }
        .hover-btn-fill:hover {
            color: #F5F4F2 !important;
            border-color: #A50020 !important;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-on-load {
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        .delay-300 { animation-delay: 300ms; }
    </style>

    <!-- Marble Texture Overlay (Global) -->
    <div class="fixed inset-0 pointer-events-none z-[-1] opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.015%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');">
    </div>

    <!-- 404 Section -->
    <main class="min-h-screen flex overflow-hidden border-black/10 border-b pt-20 relative items-center justify-center">
        <!-- Background Image with Soft Blending -->
        <div class="absolute inset-0 pointer-events-none z-0">
            <img src="https://images.unsplash.com/photo-1629946832022-c327f74956e0?w=2160&q=80" alt="Architectural Structure" class="w-full h-full object-cover object-center opacity-25 mix-blend-multiply grayscale">
            <div class="absolute inset-0 bg-[#FAFAF9]/85 backdrop-blur-[2px]"></div>
            <div class="absolute inset-0 bg-gradient-to-b from-[#FAFAF9]/50 via-transparent to-[#FAFAF9]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-transparent via-transparent to-[#FAFAF9]/80"></div>
        </div>

        <div class="z-10 w-full max-w-[1440px] mx-auto px-6 md:px-12 relative flex flex-col items-center text-center">
            <div class="max-w-3xl flex flex-col items-center">
                <div class="inline-flex animate-on-load mb-6 gap-x-3 gap-y-3 items-center">
                    <span class="text-[#A50020] text-xs">◆</span>
                    <p class="uppercase text-sm font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans">
                        Error 404
                    </p>
                    <span class="text-[#A50020] text-xs">◆</span>
                </div>

                <h1 class="font-serif text-6xl md:text-8xl lg:text-[8rem] leading-[1] tracking-tighter text-[#1A1A1A] font-normal mb-8 animate-on-load delay-100">
                    Void <br>
                    <span class="font-light italic text-[#A50020]">Encountered.</span>
                </h1>

                <p class="font-sans text-lg md:text-xl font-light text-[#4A4744] leading-relaxed mb-12 max-w-xl animate-on-load delay-200">
                    The page you are attempting to access does not exist in our current architecture or has been relocated.
                </p>

                <div class="flex flex-col sm:flex-row gap-5 animate-on-load delay-300">
                    <a href="/" class="inline-flex items-center justify-center hover-btn-fill transition-all text-sm font-medium text-[#F5F4F2] tracking-widest uppercase bg-[#1A1A1A] border-[#1A1A1A] border rounded-sm py-4 px-10 shadow-lg hover:shadow-xl group">
                        <iconify-icon icon="solar:arrow-left-linear" width="20" class="mr-3 group-hover:-translate-x-1 transition-transform"></iconify-icon>
                        Return to Base
                    </a>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const hamburgerBtn = document.getElementById('hamburger-btn');
            const closeBtn = document.getElementById('close-menu');
            const mobileMenu = document.getElementById('mobile-menu');

            if (!hamburgerBtn || !closeBtn || !mobileMenu) return;

            const mobileLinks = (mobileMenu as HTMLElement).querySelectorAll('a');

            function openMenu() {
                (mobileMenu as HTMLElement).classList.remove('hidden');
                (mobileMenu as HTMLElement).classList.add('flex');
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => {
                        (mobileMenu as HTMLElement).classList.remove('opacity-0');
                    });
                });
                document.body.style.overflow = 'hidden';
            }

            function closeMenuFunc(callback?: () => void) {
                (mobileMenu as HTMLElement).classList.add('opacity-0');
                document.body.style.overflow = '';
                setTimeout(() => {
                    (mobileMenu as HTMLElement).classList.add('hidden');
                    (mobileMenu as HTMLElement).classList.remove('flex');
                    if (callback) callback();
                }, 300);
            }

            hamburgerBtn.addEventListener('click', openMenu);
            closeBtn.addEventListener('click', () => closeMenuFunc());

            mobileLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    const href = link.getAttribute('href');
                    if (href && href.startsWith('/#')) {
                        closeMenuFunc();
                    } else {
                        closeMenuFunc();
                    }
                });
            });
        });
    </script>

</BaseLayout>
