---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing | Transparent Costs for Web Development & Apps" description="Simple, transparent pricing for web development, applications, and digital services. No hidden fees. Elite engineering at accessible costs from Hydra Dynamics.">

<style is:global>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500&display=swap');

        .font-serif {
            font-family: 'Cormorant Garamond', serif;
        }

        .font-sans {
            font-family: 'Outfit', sans-serif;
        }

        ::selection {
            background-color: #A50020;
            color: #F5F4F2;
        }

        .hover-crimson-lift {
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .hover-crimson-lift:hover {
            box-shadow: 0 20px 40px -15px rgba(165, 0, 32, 0.2);
            border-color: rgba(165, 0, 32, 0.4);
            transform: translateY(-4px);
        }

        .hover-btn-fill {
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .hover-btn-fill::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #A50020;
            z-index: -1;
            clip-path: circle(0% at 50% 120%);
            transition: clip-path 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .hover-btn-fill:hover::before {
            clip-path: circle(150% at 50% 120%);
        }

        .hover-btn-fill:hover {
            color: #F5F4F2 !important;
            border-color: #A50020 !important;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-on-load {
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }

        .delay-100 {
            animation-delay: 100ms;
        }

        .delay-200 {
            animation-delay: 200ms;
        }

        .delay-300 {
            animation-delay: 300ms;
        }

        .delay-400 {
            animation-delay: 400ms;
        }

        .calc-toggle {
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .calc-toggle.active {
            background-color: #050505;
            color: #F5F4F2;
            border-color: #050505;
        }

        .calc-toggle:not(.active):hover {
            border-color: rgba(165, 0, 32, 0.4);
            color: #1A1A1A;
        }

        .mode-toggle-btn {
            transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .mode-toggle-btn.active {
            color: #F5F4F2;
        }

        .mode-toggle-btn:not(.active) {
            color: #4A4744;
        }

        .mode-toggle-btn:not(.active):hover {
            color: #1A1A1A;
        }

        .scope-chip {
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: pointer;
            user-select: none;
        }

        .scope-chip.active {
            background-color: #1A1A1A;
            color: #F5F4F2;
            border-color: #1A1A1A;
        }

        .scope-chip.active .addon-label {
            color: #F5F4F2;
        }

        .scope-chip.active .addon-desc {
            color: rgba(245, 244, 242, 0.6);
        }

        .scope-chip.active .addon-price {
            color: #FF6B7A;
        }

        .scope-chip.active .addon-icon {
            color: rgba(245, 244, 242, 0.7);
        }

        .scope-chip:not(.active):hover {
            border-color: rgba(165, 0, 32, 0.4);
            background-color: rgba(165, 0, 32, 0.02);
        }

        .branding-option {
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: pointer;
            user-select: none;
        }

        .branding-option.active {
            background-color: #1A1A1A;
            color: #F5F4F2;
            border-color: #1A1A1A;
        }

        .branding-option.active .branding-label {
            color: #F5F4F2;
        }

        .branding-option.active .branding-desc {
            color: rgba(245, 244, 242, 0.6);
        }

        .branding-option.active .branding-price {
            color: #FF6B7A;
        }

        .branding-option.active .branding-icon {
            color: rgba(245, 244, 242, 0.7);
        }

        .branding-option.active .branding-feature {
            color: rgba(245, 244, 242, 0.5);
        }

        .branding-option.active .branding-feature iconify-icon {
            color: #FF6B7A;
        }

        .branding-option:not(.active):hover {
            border-color: rgba(165, 0, 32, 0.4);
            background-color: rgba(165, 0, 32, 0.02);
        }

        .stepper-btn {
            transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .stepper-btn:hover {
            background-color: #1A1A1A;
            color: #F5F4F2;
            border-color: #1A1A1A;
        }

        .stepper-btn:active {
            transform: scale(0.92);
        }

        .crud-chip {
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            cursor: pointer;
            user-select: none;
        }

        .crud-chip.active {
            background-color: #1A1A1A;
            color: #F5F4F2;
            border-color: #1A1A1A;
        }

        .crud-chip.active .crud-label {
            color: #F5F4F2;
        }

        .crud-chip.active .crud-desc {
            color: rgba(245, 244, 242, 0.6);
        }

        .crud-chip.active .crud-price {
            color: #FF6B7A;
        }

        .crud-chip.active .crud-icon {
            color: rgba(245, 244, 242, 0.7);
        }

        .crud-chip.active .crud-monthly-tag {
            background-color: rgba(255, 107, 122, 0.15);
            color: #FF6B7A;
            border-color: rgba(255, 107, 122, 0.3);
        }

        .crud-chip:not(.active):hover {
            border-color: rgba(165, 0, 32, 0.4);
            background-color: rgba(165, 0, 32, 0.02);
        }

        @keyframes countUp {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .price-animate {
            animation: countUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Style-only polish for better fit across breakpoints */
        body {
            line-height: 1.55;
            text-wrap: pretty;
        }

        @media (max-width: 1024px) {
            h2.font-serif {
                line-height: 1.12;
            }
        }

        @media (max-width: 768px) {
            h1.font-serif {
                font-size: clamp(2.2rem, 10vw, 3.4rem) !important;
                line-height: 1.08 !important;
            }

            h2.font-serif {
                font-size: clamp(1.9rem, 8vw, 2.8rem) !important;
                line-height: 1.12 !important;
            }

            p.font-sans {
                line-height: 1.68;
            }

            #mobile-menu .mobile-link {
                letter-spacing: 0.06em;
            }
        }

        @media (max-width: 480px) {
            h1.font-serif {
                letter-spacing: -0.02em;
            }

            h2.font-serif {
                letter-spacing: -0.015em;
            }
        }
</style>

    <!-- Texture Overlay -->
    <div class="fixed inset-0 pointer-events-none z-[-1] opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.015%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');">
    </div>

    <!-- SECTION 1: Pricing Hero -->
    <section class="relative overflow-hidden border-b border-white/10 pt-20">
        <div class="absolute inset-0 pointer-events-none z-0">
            <img src="https://images.unsplash.com/photo-1629946832022-c327f74956e0?w=2160&q=80" alt="Architectural Structure" class="w-full h-full object-cover object-right opacity-25 mix-blend-multiply grayscale">
            <div class="absolute inset-0 bg-gradient-to-r from-[#FAFAF9] via-[#FAFAF9]/95 md:via-[#FAFAF9]/70 to-transparent">
            </div>
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#FAFAF9]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-transparent via-transparent to-[#FAFAF9]/80"></div>
        </div>

        <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-12 pt-28 pb-28 md:pt-36 md:pb-36 flex flex-col items-start md:items-start text-left md:max-w-none">
            <div class="max-w-3xl">
                <p class="uppercase text-sm font-semibold text-[#A50020] tracking-[0.3em] font-sans mb-6 animate-on-load">
                    Pricing Framework
                </p>
                <h1 class="font-serif text-5xl md:text-6xl lg:text-[5.5rem] leading-[1.05] tracking-tighter font-normal mb-6 animate-on-load delay-100 text-[#1A1A1A]">
                    Start Where You Are.<br>
                    <span class="font-light italic text-[#A50020]">Grow Into What You Need.</span>
                </h1>
                <p class="font-sans text-xl md:text-2xl font-light leading-relaxed max-w-xl animate-on-load delay-200">
                    This is not a fixed price list. It is a modular system engineered for businesses at different stages
                    — scope what you need today, expand when you're ready.
                </p>
                <div class="mt-10 animate-on-load delay-300">
                    <iconify-icon icon="solar:arrow-down-linear" width="24" class="text-[#1A1A1A]/20" style="stroke-width:1.5"></iconify-icon>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 2 & 3: Calculator + Scope Categories -->
    <section class="relative bg-[#FAFAF9] border-b border-black/10 py-24 md:py-32">
        <div class="max-w-[1440px] mx-auto px-6 md:px-12">

            <div class="max-w-2xl mb-16">
                <p class="uppercase text-sm font-semibold text-[#A50020] tracking-[0.3em] font-sans mb-6">
                    <span class="text-[#A50020] text-[8px] mr-2">◆</span> Cost Calculator
                </p>
                <h2 class="font-serif text-4xl md:text-5xl tracking-tighter font-normal text-[#1A1A1A] mb-6">
                    See Your Price <span class="font-light italic text-[#A50020]">Before</span> You Speak to Anyone
                </h2>
                <p class="font-sans text-lg md:text-xl font-light text-[#4A4744] leading-relaxed">
                    Select your architecture, toggle the services you need, and watch the estimate update in real time.
                    No forms. No discovery calls. Just honest numbers.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

                <!-- LEFT: Inputs -->
                <div class="lg:col-span-2 flex flex-col gap-6">

                    <!-- Delivery Mode Toggle (Inline) -->
                    <div class="p-8 md:p-10 bg-white border border-black/10 rounded-sm">
                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
                            <div>
                                <p class="uppercase text-lg font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans mb-2 flex items-center gap-2">
                                    Project type
                                </p>
                                <p class="font-sans text-lg font-light text-[#4A4744]">Select the fundamental
                                    architecture of your project.</p>
                            </div>
                            <div class="relative flex items-center bg-[#1A1A1A]/95 backdrop-blur-xl border border-white/15 rounded-full p-1.5 shadow-[0_8px_32px_-8px_rgba(0,0,0,0.5),0_0_0_1px_rgba(255,255,255,0.05)] flex-shrink-0">
                                <div id="mode-slider" class="absolute top-1.5 left-1.5 h-[calc(100%-12px)] rounded-full bg-[#A50020] shadow-[0_0_20px_-4px_rgba(165,0,32,0.5)] transition-all duration-[400ms] cubic-bezier(0.16,1,0.3,1)" style="width: calc(50% - 6px); transform: translateX(0);"></div>
                                <button id="toggle-website" class="mode-toggle-btn active relative z-10 px-6 sm:px-8 py-2.5 text-sm font-medium uppercase tracking-widest transition-colors duration-300 text-white rounded-full whitespace-nowrap">Website</button>
                                <button id="toggle-webapp" class="mode-toggle-btn relative z-10 px-6 sm:px-8 py-2.5 text-sm font-medium uppercase tracking-widest transition-colors duration-300 text-white/50 rounded-full whitespace-nowrap">Web App</button>
                            </div>
                        </div>
                    </div>

                    <!-- ==================================== -->
                    <!-- WEBSITE CONTENT -->
                    <!-- ==================================== -->
                    <div id="content-website" class="flex flex-col gap-6">

                        <!-- Website Features (Multi-select) -->
                        <div class="p-8 md:p-10 bg-white border border-black/10 rounded-sm">
                            <p class="uppercase text-lg font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans mb-2 flex items-center gap-2">
                                Website Features
                            </p>
                            <p class="font-sans text-lg font-light text-[#4A4744] mb-6">Select all that apply to your
                                project scope.</p>
                            <div class="flex flex-wrap gap-3" id="website-features">
                                <button data-label="Landing Page" data-price="800" class="calc-toggle multi px-6 py-3.5 border border-black/20 rounded-sm text-sm font-sans font-light tracking-widest uppercase text-[#4A4744]">CMS</button>
                                <button data-label="Multi-Page Site" data-price="2400" class="calc-toggle multi px-6 py-3.5 border border-black/20 rounded-sm text-sm font-sans font-light tracking-widest uppercase text-[#4A4744]">User Account</button>
                                <button data-label="E-Commerce" data-price="4000" class="calc-toggle multi px-6 py-3.5 border border-black/20 rounded-sm text-sm font-sans font-light tracking-widest uppercase text-[#4A4744]">E-Commerce</button>
                            </div>
                        </div>

                        <!-- Page & Section Calculator -->
                        <div class="p-8 md:p-10 bg-white border border-black/10 rounded-sm">
                            <p class="uppercase text-lg font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans mb-2 flex items-center gap-2">
                                Page Structure
                            </p>
                            <p class="font-sans text-lg font-light text-[#4A4744] mb-8">Define the scale and depth of
                                your website's page architecture.</p>

                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                                <div class="flex flex-col items-center p-6 border border-black/8 rounded-sm bg-[#FAFAF9]/60">
                                    <p class="font-sans text-sm font-medium text-[#1A1A1A] tracking-wide uppercase mb-1">
                                        Normal Pages</p>
                                    <p class="font-sans text-lg font-light text-[#4A4744] mb-6">Primary Digital Site Pages</p>
                                    <div class="flex items-center gap-5">
                                        <button class="stepper-btn decrement w-10 h-10 flex items-center justify-center border border-black/15 rounded-sm text-[#1A1A1A] bg-white" data-target="page-count-value">
                                            <iconify-icon icon="solar:minus-circle-linear" width="20" style="stroke-width:1.5"></iconify-icon>
                                        </button>
                                        <span id="page-count-value" class="font-serif text-5xl tracking-tighter text-[#1A1A1A] leading-none min-w-[3ch] text-center select-none" data-value="5" data-min="1" data-max="30" data-unit-cost="80" data-unit-name="Normal Page">5</span>
                                        <button class="stepper-btn increment w-10 h-10 flex items-center justify-center border border-black/15 rounded-sm text-[#1A1A1A] bg-white" data-target="page-count-value">
                                            <iconify-icon icon="solar:add-circle-linear" width="20" style="stroke-width:1.5"></iconify-icon>
                                        </button>
                                    </div>
                                    <p class="font-sans text-sm font-light text-[#4A4744]/60 mt-4 tracking-wider uppercase">
                                        $80 per page</p>
                                </div>
                                <div class="flex flex-col items-center p-6 border border-black/8 rounded-sm bg-[#FAFAF9]/60">
                                    <p class="font-sans text-sm font-medium text-[#1A1A1A] tracking-wide uppercase mb-1">
                                        Landing Pages</p>
                                    <p class="font-sans text-lg font-light text-[#4A4744] mb-6">High-impact conversion
                                        pages</p>
                                    <div class="flex items-center gap-5">
                                        <button class="stepper-btn decrement w-10 h-10 flex items-center justify-center border border-black/15 rounded-sm text-[#1A1A1A] bg-white" data-target="landing-count-value">
                                            <iconify-icon icon="solar:minus-circle-linear" width="20" style="stroke-width:1.5"></iconify-icon>
                                        </button>
                                        <span id="landing-count-value" class="font-serif text-5xl tracking-tighter text-[#1A1A1A] leading-none min-w-[3ch] text-center select-none" data-value="1" data-min="0" data-max="10" data-unit-cost="200" data-unit-name="Landing Page">1</span>
                                        <button class="stepper-btn increment w-10 h-10 flex items-center justify-center border border-black/15 rounded-sm text-[#1A1A1A] bg-white" data-target="landing-count-value">
                                            <iconify-icon icon="solar:add-circle-linear" width="20" style="stroke-width:1.5"></iconify-icon>
                                        </button>
                                    </div>
                                    <p class="font-sans text-sm font-light text-[#4A4744]/60 mt-4 tracking-wider uppercase">
                                        $200 per page</p>
                                </div>
                                <div class="flex flex-col items-center p-6 border border-black/8 rounded-sm bg-[#FAFAF9]/60">
                                    <p class="font-sans text-sm font-medium text-[#1A1A1A] tracking-wide uppercase mb-1">
                                        Sections per Page</p>
                                    <p class="font-sans text-lg font-light text-[#4A4744] mb-6">Average, excl. header
                                        &amp; footer</p>
                                    <div class="flex items-center gap-5">
                                        <button class="stepper-btn decrement w-10 h-10 flex items-center justify-center border border-black/15 rounded-sm text-[#1A1A1A] bg-white" data-target="section-count-value">
                                            <iconify-icon icon="solar:minus-circle-linear" width="20" style="stroke-width:1.5"></iconify-icon>
                                        </button>
                                        <span id="section-count-value" class="font-serif text-5xl tracking-tighter text-[#1A1A1A] leading-none min-w-[3ch] text-center select-none" data-value="4" data-min="1" data-max="15" data-unit-cost="60" data-unit-name="Section">4</span>
                                        <button class="stepper-btn increment w-10 h-10 flex items-center justify-center border border-black/15 rounded-sm text-[#1A1A1A] bg-white" data-target="section-count-value">
                                            <iconify-icon icon="solar:add-circle-linear" width="20" style="stroke-width:1.5"></iconify-icon>
                                        </button>
                                    </div>
                                    <p class="font-sans text-sm font-light text-[#4A4744]/60 mt-4 tracking-wider uppercase">
                                        $60 per section</p>
                                </div>
                            </div>

                            <div class="flex items-center gap-2.5 mt-6 pt-5 border-t border-black/5">
                                <iconify-icon icon="solar:info-circle-linear" width="16" class="text-[#A50020]/60 flex-shrink-0" style="stroke-width:1.5"></iconify-icon>
                                <p class="font-sans text-lg font-light text-[#4A4744]/70 leading-relaxed">A global
                                    header and footer are already included with every website — no additional charge.
                                </p>
                            </div>
                        </div>

                        <!-- Branding Tier Selection -->
                        <div class="p-8 md:p-10 bg-white border border-black/10 rounded-sm">
                            <p class="uppercase text-lg font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans mb-2 flex items-center gap-2">
                                Branding Package
                            </p>
                            <p class="font-sans text-lg font-light text-[#4A4744] leading-relaxed mb-8">
                                Choose your branding tier. Select one — or skip this entirely if you already have
                                established brand assets.
                            </p>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="branding-options">
                                <!-- Foundational Branding -->
                                <div data-price="1200" data-label="Foundational Branding" class="branding-option active flex flex-col p-6 border border-black/10 rounded-sm">
                                    <div class="flex items-start justify-between mb-4">
                                        <div class="flex items-center gap-3">
                                            <iconify-icon icon="solar:palette-linear" width="24" class="branding-icon text-[#4A4744]" style="stroke-width:1.5"></iconify-icon>
                                            <p class="branding-label font-sans text-sm font-medium text-[#1A1A1A] tracking-wide uppercase">
                                                Foundational Branding</p>
                                        </div>
                                    </div>
                                    <p class="branding-desc font-sans text-base font-light text-[#4A4744] leading-relaxed mb-4 flex-1">
                                        Logo design, color palette, typography selection, and a concise brand style
                                        guide.
                                    </p>
                                    <ul class="flex flex-col gap-2 mb-5">
                                        <li class="branding-feature flex items-center gap-2 font-sans text-base font-light text-[#4A4744]/70">
                                            <iconify-icon icon="solar:check-circle-linear" width="16" class="text-[#A50020]/50 flex-shrink-0" style="stroke-width:1.5"></iconify-icon>Logo + Wordmark
                                        </li>
                                        <li class="branding-feature flex items-center gap-2 font-sans text-base font-light text-[#4A4744]/70">
                                            <iconify-icon icon="solar:check-circle-linear" width="16" class="text-[#A50020]/50 flex-shrink-0" style="stroke-width:1.5"></iconify-icon>Color System
                                        </li>
                                        <li class="branding-feature flex items-center gap-2 font-sans text-base font-light text-[#4A4744]/70">
                                            <iconify-icon icon="solar:check-circle-linear" width="16" class="text-[#A50020]/50 flex-shrink-0" style="stroke-width:1.5"></iconify-icon>Typography Pairing
                                        </li>
                                        <li class="branding-feature flex items-center gap-2 font-sans text-base font-light text-[#4A4744]/70">
                                            <iconify-icon icon="solar:check-circle-linear" width="16" class="text-[#A50020]/50 flex-shrink-0" style="stroke-width:1.5"></iconify-icon>Basic Style Guide
                                        </li>
                                    </ul>
                                    <p class="branding-price font-serif text-xl text-[#A50020]">+$1,200</p>
                                </div>

                                <!-- Elite Branding -->
                                <div data-price="3500" data-label="Elite Branding" class="branding-option flex flex-col p-6 border border-black/10 rounded-sm">
                                    <div class="flex items-start justify-between mb-4">
                                        <div class="flex items-center gap-3">
                                            <iconify-icon icon="solar:crown-linear" width="24" class="branding-icon text-[#4A4744]" style="stroke-width:1.5"></iconify-icon>
                                            <p class="branding-label font-sans text-sm font-medium text-[#1A1A1A] tracking-wide uppercase">
                                                Elite Branding</p>
                                        </div>
                                    </div>
                                    <p class="branding-desc font-sans text-base font-light text-[#4A4744] leading-relaxed mb-4 flex-1">
                                        Full identity system with strategy, extensive guidelines, collateral templates,
                                        and brand narrative.
