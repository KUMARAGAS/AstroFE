    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const hamburgerBtn = document.getElementById('hamburger-btn');
            const closeBtn = document.getElementById('close-menu');
            const mobileMenu = document.getElementById('mobile-menu');
            const mobileLinks = mobileMenu.querySelectorAll('a');
            function openMenu() { mobileMenu.classList.remove('hidden'); mobileMenu.classList.add('flex'); requestAnimationFrame(() => { requestAnimationFrame(() => { mobileMenu.classList.remove('opacity-0'); }); }); document.body.style.overflow = 'hidden'; }
            function closeMenuFunc(cb) { mobileMenu.classList.add('opacity-0'); document.body.style.overflow = ''; setTimeout(() => { mobileMenu.classList.add('hidden'); mobileMenu.classList.remove('flex'); if (cb) cb(); }, 300); }
            hamburgerBtn.addEventListener('click', openMenu);
            closeBtn.addEventListener('click', () => closeMenuFunc());
            mobileLinks.forEach(l => { l.addEventListener('click', (e) => { const h = l.getAttribute('href'); if (h && h.startsWith('#')) { e.preventDefault(); closeMenuFunc(() => { const t = document.querySelector(h); if (t) t.scrollIntoView({ behavior: 'smooth' }); }); } else closeMenuFunc(); }); });

            const contentWebsite = document.getElementById('content-website');
            const contentWebapp = document.getElementById('content-webapp');
            const priceOnetimeEl = document.getElementById('price-onetime');
            const priceMonthlyEl = document.getElementById('price-monthly');
            const summaryList = document.getElementById('summary-list');
            const totalOverDuration = document.getElementById('total-over-duration');
            const priceTotalDuration = document.getElementById('price-total-duration');
            const durationLabel = document.getElementById('duration-label');

            let currentMode = 'website';

            const toggleWebsite = document.getElementById('toggle-website');
            const toggleWebapp = document.getElementById('toggle-webapp');
            const modeSlider = document.getElementById('mode-slider');

            toggleWebsite.addEventListener('click', () => setMode('website'));
            toggleWebapp.addEventListener('click', () => setMode('webapp'));

            function setMode(mode) {
                currentMode = mode;
                if (mode === 'website') {
                    modeSlider.style.transform = 'translateX(0)';
                    toggleWebsite.classList.add('active');
                    toggleWebapp.classList.remove('active');
                    contentWebsite.classList.remove('hidden');
                    contentWebapp.classList.add('hidden');
                } else {
                    modeSlider.style.transform = 'translateX(100%)';
                    toggleWebapp.classList.add('active');
                    toggleWebsite.classList.remove('active');
                    contentWebapp.classList.remove('hidden');
                    contentWebsite.classList.add('hidden');
                }
                recalc();
            }

            document.querySelectorAll('.calc-toggle.multi').forEach(btn => {
                btn.addEventListener('click', () => {
                    btn.classList.toggle('active');
                    recalc();
                });
            });

            document.querySelectorAll('.stepper-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const targetId = btn.dataset.target;
                    const targetEl = document.getElementById(targetId);
                    let val = parseInt(targetEl.dataset.value);
                    const min = parseInt(targetEl.dataset.min);
                    const max = parseInt(targetEl.dataset.max);

                    if (btn.classList.contains('increment')) {
                        val = Math.min(val + 1, max);
                    } else {
                        val = Math.max(val - 1, min);
                    }
                    targetEl.dataset.value = val;
                    targetEl.textContent = val;
                    recalc();
                });

                let holdTimer = null;
                let holdInterval = null;
                btn.addEventListener('mousedown', () => {
                    holdTimer = setTimeout(() => {
                        holdInterval = setInterval(() => { btn.click(); }, 80);
                    }, 400);
                });
                btn.addEventListener('mouseup', () => { clearTimeout(holdTimer); clearInterval(holdInterval); });
                btn.addEventListener('mouseleave', () => { clearTimeout(holdTimer); clearInterval(holdInterval); });
                btn.addEventListener('touchstart', (e) => {
                    holdTimer = setTimeout(() => {
                        holdInterval = setInterval(() => { btn.click(); }, 80);
                    }, 400);
                });
                btn.addEventListener('touchend', () => { clearTimeout(holdTimer); clearInterval(holdInterval); });
            });

            document.querySelectorAll('.scope-chip').forEach(chip => {
                chip.addEventListener('click', () => {
                    chip.classList.toggle('active');
                    const indicator = chip.querySelector('.check-indicator');
                    if(chip.classList.contains('active')) {
                        indicator.innerHTML = '<iconify-icon icon="solar:check-read-linear" width="16" class="text-white" style="stroke-width:1.5"></iconify-icon>';
                    } else {
                        indicator.innerHTML = '';
                    }
                    recalc();
                });
            });

            const brandingOptions = document.querySelectorAll('#branding-options .branding-option');
            brandingOptions.forEach(option => {
                option.addEventListener('click', () => {
                    const wasActive = option.classList.contains('active');
                    brandingOptions.forEach(o => o.classList.remove('active'));
                    if (!wasActive) option.classList.add('active');
                    recalc();
                });
            });

            function recalc() {
                const activeContainer = currentMode === 'website' ? contentWebsite : contentWebapp;

                let onetime = 0;
                let monthly = 0;
                let summaryItems = [];

                // Multi-select toggles
                activeContainer.querySelectorAll('.calc-toggle.multi.active').forEach(btn => {
                    onetime += parseInt(btn.dataset.price);
                    summaryItems.push(btn.dataset.label);
                });

                // Steppers (excluding duration-months-value which doesn't directly compute to onetime)
                activeContainer.querySelectorAll('[id$="-value"]').forEach(stepper => {
                    if (stepper.id === 'duration-months-value') return; 
                    const val = parseInt(stepper.dataset.value);
                    const unitCost = parseInt(stepper.dataset.unitCost);
                    const unitName = stepper.dataset.unitName;
                    const stepperCost = val * unitCost;
                    onetime += stepperCost;
                    if (val > 0) summaryItems.push(`${val} ${unitName}${val !== 1 ? 's' : ''}`);
                });

                // Scope chips (add-ons)
                activeContainer.querySelectorAll('.scope-chip.active').forEach(chip => {
                    const price = parseInt(chip.dataset.price);
                    const isMonthly = chip.dataset.monthly === 'true';
                    const label = chip.querySelector('.addon-label').innerText;

                    if (isMonthly) monthly += price;
                    else onetime += price;
                    summaryItems.push(label);
                });

                if (currentMode === 'webapp') {
                    const durationEl = document.getElementById('duration-months-value');
                    const months = parseInt(durationEl.dataset.value);

                    if (months > 0) summaryItems.push(`${months} Month Allocation`);

                    if (monthly > 0) {
                        totalOverDuration.classList.remove('hidden');
                        durationLabel.textContent = months;
                        const totalDuration = onetime + (monthly * months);
                        priceTotalDuration.textContent = totalDuration.toLocaleString();
                    } else {
                        totalOverDuration.classList.add('hidden');
                    }
                } else {
                    totalOverDuration.classList.add('hidden');
                }

                // Branding (website only)
                if (currentMode === 'website') {
                    const activeBranding = activeContainer.querySelector('#branding-options .branding-option.active');
                    if (activeBranding) {
                        onetime += parseInt(activeBranding.dataset.price);
                        summaryItems.push(activeBranding.dataset.label);
                    }
                }

                priceOnetimeEl.textContent = onetime.toLocaleString();
                priceMonthlyEl.textContent = monthly.toLocaleString();

                summaryList.innerHTML = '';
                function addSummaryItem(text) {
                    const li = document.createElement('li');
                    li.className = 'flex items-center gap-2.5 font-sans text-base font-light text-white/60';
                    li.innerHTML = `<iconify-icon icon="solar:check-circle-linear" width="18" class="text-[#FF3344] flex-shrink-0" style="stroke-width:1.5"></iconify-icon><span>${text}</span>`;
                    summaryList.appendChild(li);
                }

                summaryItems.forEach(item => addSummaryItem(item));

                if (currentMode === 'website') addSummaryItem('Header & Footer');
                if (currentMode === 'webapp') addSummaryItem('Nav Shell & Layout');
            }

            recalc();
        });
    </script>

