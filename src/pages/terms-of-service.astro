---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLegalContent } from '../lib/directus.js';
const legal = await getLegalContent();
---
<BaseLayout title="Terms of Service">
  <section class="page-hero"><span class="label">Legal</span><h1>Terms of Service</h1></section>
  <section class="legal"><div class="container"><div class="content" set:html={legal.core_terms_of_service}/></div></section>
</BaseLayout>
<style>
  .legal { padding: 80px 0; background: var(--dark-2); }
  .content { max-width: 800px; margin: 0 auto; color: var(--text-muted); line-height: 1.9; font-size: 16px; }
  .content h2 { color: var(--text); font-size: 24px; font-weight: 400; margin: 40px 0 16px; }
  .content a { color: var(--gold); text-decoration: none; }
</style>