---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSiteSettings, getBusinessDetails } from '../lib/directus.js';

const site = await getSiteSettings();
const business = await getBusinessDetails();

const siteSettings = {
  core_logo_light: site?.core_logo_light,
  core_site_name: site?.core_site_name || 'HYDRA Dynamics'
};
---

<html lang="en" class="scroll-smooth scroll-pt-20">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hydra Dynamics | Engineering Digital Permanence</title>
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" is:inline></script>
    <style is:global>
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Outfit:wght@300;400;500&display=swap');

        /* Base Typography */
        .font-serif { font-family: 'Cormorant Garamond', serif; }
        .font-sans { font-family: 'Outfit', sans-serif; }

        /* Custom Utilities & Animations */
        ::selection {
            background-color: #A50020;
            color: #F5F4F2;
        }

        .hover-crimson-lift {
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hover-crimson-lift:hover {
            box-shadow: 0 20px 40px -15px rgba(165, 0, 32, 0.2);
            border-color: rgba(165, 0, 32, 0.4);
            transform: translateY(-4px);
        }

        .hover-btn-fill {
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        .hover-btn-fill::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #A50020;
            z-index: -1;
            clip-path: circle(0% at 50% 120%);
            transition: clip-path 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .hover-btn-fill:hover::before {
            clip-path: circle(150% at 50% 120%);
        }
        .hover-btn-fill:hover {
            color: #F5F4F2 !important;
            border-color: #A50020 !important;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-on-load {
            animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        .delay-300 { animation-delay: 300ms; }
    </style>
</head>
<body class="antialiased overflow-x-hidden text-[#4A4744] font-sans bg-[#FAFAF9]">

    <!-- Marble Texture Overlay (Global) -->
    <div class="fixed inset-0 pointer-events-none z-[-1] opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.015%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');">
    </div>

    <Nav siteSettings={siteSettings} />

    <!-- Hero Section -->
    <header class="min-h-screen flex overflow-hidden border-black/10 border-b pt-20 relative items-center">
        <!-- Background Image with Soft Blending -->
        <div class="absolute inset-0 pointer-events-none z-0">
            <img src="https://images.unsplash.com/photo-1629946832022-c327f74956e0?w=2160&q=80" alt="Architectural Structure" class="w-full h-full object-cover object-right opacity-25 mix-blend-multiply grayscale">
            <div class="absolute inset-0 bg-gradient-to-r from-[#FAFAF9] via-[#FAFAF9]/95 md:via-[#FAFAF9]/70 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#FAFAF9]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-transparent via-transparent to-[#FAFAF9]/80"></div>
        </div>
        <div class="z-10 w-full max-w-[1440px] mx-auto px-6 md:px-12 relative">
            <div class="max-w-3xl">
                <div class="inline-flex animate-on-load mb-8 pt-2 pr-1 pb-2 pl-1 gap-x-3 gap-y-3 items-center">
                    <p class="uppercase text-sm font-semibold text-[#1A1A1A] tracking-[0.25em] font-sans">
                        Engineering Imperial Standards
                    </p>
                </div>
                <h1 class="font-serif text-6xl md:text-7xl lg:text-[6.5rem] leading-[1.05] tracking-tighter text-[#1A1A1A] font-normal mb-8 animate-on-load delay-100">
                    Digital Permanence,<br>
                    <span class="font-light italic text-[#A50020]">Engineered.</span>
                </h1>
                <p class="font-sans text-lg md:text-xl font-light text-[#4A4744] leading-relaxed mb-12 max-w-xl animate-on-load delay-200">
                    Elite-grade engineering without the agency tax. From high-converting Astro landing pages to complex full-suite systems architected to outlast.
                </p>
                <div class="flex flex-col sm:flex-row gap-5 animate-on-load delay-300">
                    <a href="#contact" class="inline-flex items-center justify-center hover-btn-fill transition-all text-sm font-medium text-[#F5F4F2] tracking-widest uppercase bg-[#1A1A1A] border-[#1A1A1A] border rounded-sm py-4 px-10 shadow-lg hover:shadow-xl">Schedule a Call</a>
                    <a href="#process" class="inline-flex items-center justify-center hover:bg-black/5 transition-all text-sm font-medium text-[#1A1A1A] tracking-widest uppercase bg-transparent border-black/20 border rounded-sm py-4 px-10 backdrop-blur-sm">
                        Explore Methodology
                    </a>
                </div>
            </div>
        </div>
    </header>

    <!-- Trust Bar -->
    <section class="border-b bg-[#FAFAF9]/80 border-black/10 py-12 px-6 md:px-12 backdrop-blur-md relative overflow-hidden">
        <div class="max-w-[1440px] mx-auto flex flex-col md:flex-row items-center justify-between gap-8 opacity-60 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-700">
            <p class="font-sans text-xs uppercase tracking-[0.3em] text-[#1A1A1A] font-semibold text-center md:text-left w-full md:w-auto">
                Trusted by Visionaries
            </p>
            <div class="flex flex-wrap justify-center font-serif tracking-widest text-[#1A1A1A] uppercase text-lg gap-x-4 md:justify-end font-medium">
                <span>SRI LANKA</span>
                <span class="text-[#A50020]">◆</span>
                <span>GLOBAL</span>
            </div>
        </div>
    </section>

    <!-- Services Section (Monumental Dark) -->
    <section class="group/section overflow-hidden md:px-12 text-[#F5F4F2] bg-[#050505] pt-32 pr-6 pb-32 pl-6 relative" id="services" onmousemove="this.style.setProperty('--mouse-x', (event.clientX - this.getBoundingClientRect().left) + 'px'); this.style.setProperty('--mouse-y', (event.clientY - this.getBoundingClientRect().top) + 'px');" style="--mouse-x: 231px; --mouse-y: 24px;">
        <!-- Deep shadows and subtle structures -->
        <div class="absolute inset-0 pointer-events-none z-0">
            <!-- Vercel-style Reactive Grid -->
            <div class="absolute inset-0 pointer-events-none" style="mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);">
                <!-- Base Grid (Low Opacity) -->
                <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(to right, rgba(255,51,68, 0.04) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,51,68, 0.04) 1px, transparent 1px); background-size: 48px 48px;"></div>

                <!-- Hover Grid (Follows Mouse) -->
                <div class="absolute inset-0 pointer-events-none opacity-0 group-hover/section:opacity-100 transition-opacity duration-700" style="background-image: linear-gradient(to right, rgba(255,51,68, 0.25) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,51,68, 0.25) 1px, transparent 1px); background-size: 48px 48px; -webkit-mask-image: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), black, transparent 80%); mask-image: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), black, transparent 80%);"></div>
            </div>

            <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[#FF3344] blur-[180px] opacity-[0.12] rounded-full"></div>
            <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#FF3344] blur-[150px] opacity-[0.08] rounded-full"></div>
        </div>

        <div class="max-w-[1440px] mx-auto relative z-10">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-8">
                <div class="">
                    <p class="uppercase flex items-center gap-3 text-sm font-semibold text-[#FF3344] tracking-[0.3em] font-sans mb-5">
                         The Arsenal
                    </p>
                    <h2 class="font-serif text-5xl md:text-6xl tracking-tighter font-normal text-white">
                        Disciplines of <span class="italic text-[#FF3344]">Execution.</span>
                    </h2>
                </div>
                <p class="font-sans text-base font-light text-white/60 max-w-md leading-relaxed">
                    Every service is delivered with surgical precision. We build robust standalone products or full-suite systems, always offering an optional maintenance plan to ensure longevity.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Card 1 -->
                <div class="p-10 bg-black/40 border border-white/10 backdrop-blur-sm transition-all duration-500 hover-crimson-lift group relative overflow-hidden rounded-sm flex flex-col">
                    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#FF3344]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="w-14 h-14 rounded-sm bg-white/5 flex items-center justify-center mb-8 border border-white/10 group-hover:border-[#FF3344]/50 transition-colors">
                        <iconify-icon icon="solar:window-frame-linear" width="28" class="text-white group-hover:text-[#FF3344] transition-colors"></iconify-icon>
                    </div>
                    <h3 class="font-serif text-2xl tracking-tight mb-4 text-white">Landing Pages &amp; Sites</h3>
                    <p class="font-sans text-sm font-light text-white/50 leading-relaxed">Blisteringly fast, highly optimized marketing surfaces built exclusively with Astro for maximum conversion and zero bloat.</p>
                </div>

                <!-- Card 2 -->
                <div class="transition-all duration-500 hover-crimson-lift group overflow-hidden flex flex-col bg-black/40 border-white/10 border rounded-sm pt-10 pr-10 pb-10 pl-10 relative backdrop-blur-sm">
                    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#FF3344]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="w-14 h-14 rounded-sm bg-white/5 flex items-center justify-center mb-8 border border-white/10 group-hover:border-[#FF3344]/50 transition-colors">
                        <iconify-icon icon="solar:cart-large-linear" width="28" class="text-white group-hover:text-[#FF3344] transition-colors"></iconify-icon>
                    </div>
                    <h3 class="font-serif text-2xl tracking-tight mb-4 text-white">Ecommerce Stores</h3>
                    <p class="font-sans text-sm font-light text-white/50 leading-relaxed">Bespoke digital storefronts engineered for scale, speed, and seamless transactional flow. No generic templates.</p>
                </div>

                <!-- Card 3 -->
                <div class="p-10 bg-black/40 border border-white/10 backdrop-blur-sm transition-all duration-500 hover-crimson-lift group relative overflow-hidden rounded-sm flex flex-col">
                    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#FF3344]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="w-14 h-14 rounded-sm bg-white/5 flex items-center justify-center mb-8 border border-white/10 group-hover:border-[#FF3344]/50 transition-colors">
                        <iconify-icon icon="solar:cpu-linear" width="28" class="text-white group-hover:text-[#FF3344] transition-colors"></iconify-icon>
                    </div>
                    <h3 class="font-serif text-2xl tracking-tight mb-4 text-white">AI Chatbots (n8n)</h3>
                    <p class="font-sans text-sm font-light text-white/50 leading-relaxed">Intelligent, context-aware agents integrated via n8n to automate support, qualify leads, and elevate operations.</p>
                </div>

                <!-- Card 4 -->
                <div class="p-10 bg-black/40 border border-white/10 backdrop-blur-sm transition-all duration-500 hover-crimson-lift group relative overflow-hidden rounded-sm flex flex-col">
                    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#FF3344]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="w-14 h-14 rounded-sm bg-white/5 flex items-center justify-center mb-8 border border-white/10 group-hover:border-[#FF3344]/50 transition-colors">
                        <iconify-icon icon="solar:laptop-minimalistic-linear" width="28" class="text-white group-hover:text-[#FF3344] transition-colors"></iconify-icon>
                    </div>
                    <h3 class="font-serif text-2xl tracking-tight mb-4 text-white">Web Applications</h3>
                    <p class="font-sans text-sm font-light text-white/50 leading-relaxed">Complex, interactive platforms forged with Next.js. We turn intricate business logic into effortless user experiences.</p>
                </div>

                <!-- Card 5 -->
                <div class="p-10 bg-black/40 border border-white/10 backdrop-blur-sm transition-all duration-500 hover-crimson-lift group relative overflow-hidden rounded-sm flex flex-col">
                    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#FF3344]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="w-14 h-14 rounded-sm bg-white/5 flex items-center justify-center mb-8 border border-white/10 group-hover:border-[#FF3344]/50 transition-colors">
                        <iconify-icon icon="solar:smartphone-linear" width="28" class="text-white group-hover:text-[#FF3344] transition-colors"></iconify-icon>
                    </div>
                    <h3 class="font-serif text-2xl tracking-tight mb-4 text-white">Mobile Apps (Expo)</h3>
                    <p class="font-sans text-sm font-light text-white/50 leading-relaxed">Native-grade iOS and Android experiences built with Expo. Fluid animations, offline capabilities, uncompromising performance.</p>
                </div>

                <!-- Card 6 -->
                <div class="p-10 bg-black/40 border border-white/10 backdrop-blur-sm transition-all duration-500 hover-crimson-lift group relative overflow-hidden rounded-sm flex flex-col">
                    <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#FF3344]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="w-14 h-14 rounded-sm bg-white/5 flex items-center justify-center mb-8 border border-white/10 group-hover:border-[#FF3344]/50 transition-colors">
                        <iconify-icon icon="solar:pen-new-square-linear" width="28" class="text-white group-hover:text-[#FF3344] transition-colors"></iconify-icon>
                    </div>
                    <h3 class="font-serif text-2xl tracking-tight mb-4 text-white">Brand Identity</h3>
                    <p class="font-sans text-sm font-light text-white/50 leading-relaxed">Logos, typography, and visual systems that project authority. We design brands that feel permanent.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Process Section (Parchment & Marble) -->
    <section class="bg-[#FAFAF9] pt-32 px-6 md:px-12 pb-32 relative border-b border-black/10" id="process">
        <div class="max-w-[1440px] mx-auto relative z-10">
            <div class="text-center mb-24">
                <p class="uppercase flex items-center justify-center gap-3 text-sm font-semibold text-[#A50020] tracking-[0.3em] font-sans mb-5">
                     Methodology
                </p>
                <h2 class="font-serif text-5xl md:text-6xl tracking-tighter text-[#1A1A1A] font-normal">
                    Precision in Every Phase.
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 relative">
  <div class="relative z-10">
    <div class="mb-8 bg-[#FAFAF9] inline-block pr-6">
      <span class="inline-flex items-center justify-center w-12 h-12 bg-white border border-black/20 shadow-sm font-serif text-lg font-medium text-[#A50020]">I</span>
    </div>
    <h4 class="font-serif text-2xl tracking-tight text-[#1A1A1A] mb-3">Discovery &amp; Blueprint</h4>
    <p class="font-sans text-sm font-light text-[#4A4744] leading-relaxed">We dissect your goals, map the technical
      requirements, and define the architectural structure before a single line of code is written.</p>
  </div>

  <div class="z-10 relative">
    <div class="mb-8 bg-[#FAFAF9] inline-block pr-6">
      <span class="inline-flex items-center justify-center w-12 h-12 bg-white border border-black/20 shadow-sm font-serif text-lg font-medium text-[#A50020]">II</span>
    </div>
    <h4 class="font-serif text-2xl tracking-tight text-[#1A1A1A] mb-3">Elite Engineering</h4>
    <p class="font-sans text-sm font-light text-[#4A4744] leading-relaxed">Execution. Leveraging modern frameworks to
      build fast, scalable, and secure products. Complete transparency throughout.</p>
  </div>

  <div class="relative z-10">
    <div class="mb-8 bg-[#FAFAF9] inline-block pr-6">
      <span class="inline-flex items-center justify-center w-12 h-12 bg-white border border-black/20 shadow-sm font-serif text-lg font-medium text-[#A50020]">III</span>
    </div>
    <h4 class="font-serif text-2xl tracking-tight text-[#1A1A1A] mb-3">Deployment &amp; QA</h4>
    <p class="font-sans text-sm font-light text-[#4A4744] leading-relaxed">Rigorous testing across all devices. We
      ensure deployment is flawless, performant, and ready for global traffic.</p>
  </div>

  <div class="relative z-10">
    <div class="mb-8 bg-[#FAFAF9] inline-block pr-6">
      <span class="inline-flex items-center justify-center w-12 h-12 bg-white border border-black/20 shadow-sm font-serif text-lg font-medium text-[#A50020]">IV</span>
    </div>
    <h4 class="font-serif text-2xl tracking-tight text-[#1A1A1A] mb-3">Digital Permanence</h4>
    <p class="font-sans text-sm font-light text-[#4A4744] leading-relaxed">Optional retention plans. We stand by our
      work, providing ongoing updates, security patches, and strategic scaling.</p>
  </div>
</div>
        </div>
    </section>

    <!-- Tech Stack (Structured Grid) -->
    <section class="bg-white py-24 px-6 md:px-12 border-b border-black/10">
        <div class="max-w-[1440px] mx-auto flex flex-col lg:flex-row items-center justify-between gap-16">
            <div class="lg:w-1/3 text-center lg:text-left">
                <p class="uppercase flex items-center justify-center lg:justify-start gap-3 text-sm font-semibold text-[#A50020] tracking-[0.3em] font-sans mb-4">
                     The Foundation
                </p>
                <h2 class="font-serif text-4xl tracking-tighter text-[#1A1A1A] mb-6">Unshakeable Infrastructure.</h2>
                <p class="font-sans text-base font-light text-[#4A4744] leading-relaxed mx-auto max-w-md lg:mx-0">We eschew dated monolithic platforms. We utilize modern, decoupled technologies that guarantee speed, autonomy, and an impeccable structural integrity.</p>
            </div>

            <div class="lg:w-2/3 w-full grid grid-cols-2 md:grid-cols-4 gap-0 border border-black/10">
                <div class="p-8 bg-[#FAFAF9] border-b border-r border-black/10 hover:bg-white transition-colors group">
                    <p class="font-serif text-2xl text-[#1A1A1A] tracking-tight mb-2 group-hover:text-[#A50020] transition-colors">Astro</p>
                    <p class="font-sans text-xs text-[#4A4744] font-light uppercase tracking-widest">WebSites</p>
                </div>
                <div class="p-8 bg-[#FAFAF9] border-b md:border-r border-black/10 hover:bg-white transition-colors group">
                    <p class="font-serif text-2xl text-[#1A1A1A] tracking-tight mb-2 group-hover:text-[#A50020] transition-colors">Next.js</p>
                    <p class="font-sans text-xs text-[#4A4744] font-light uppercase tracking-widest">Applications</p>
                </div>
                <div class="p-8 bg-[#FAFAF9] border-b border-r md:border-b-0 border-black/10 hover:bg-white transition-colors group">
                    <p class="font-serif text-2xl text-[#1A1A1A] tracking-tight mb-2 group-hover:text-[#A50020] transition-colors">Expo</p>
                    <p class="font-sans text-xs text-[#4A4744] font-light uppercase tracking-widest">Mobile Apps</p>
                </div>
                <div class="p-8 bg-[#FAFAF9] border-black/10 hover:bg-white transition-colors group">
                    <p class="font-serif text-2xl text-[#1A1A1A] tracking-tight mb-2 group-hover:text-[#A50020] transition-colors">n8n</p>
                    <p class="font-sans text-xs text-[#4A4744] font-light uppercase tracking-widest">AI Chatbots</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials (Monumental Dark) -->
    <section class="group/section overflow-hidden text-[#F5F4F2] bg-[#050505] pt-32 px-6 md:px-12 pb-32 relative border-b border-white/10" id="testimonials" onmousemove="this.style.setProperty('--mouse-x', (event.clientX - this.getBoundingClientRect().left) + 'px'); this.style.setProperty('--mouse-y', (event.clientY - this.getBoundingClientRect().top) + 'px');">
        <div class="absolute inset-0 pointer-events-none z-0">
            <!-- Vercel-style Reactive Grid -->
            <div class="absolute inset-0 pointer-events-none" style="mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent); -webkit-mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);">
                <!-- Base Grid (Low Opacity) -->
                <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(to right, rgba(255,51,68, 0.04) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,51,68, 0.04) 1px, transparent 1px); background-size: 48px 48px;"></div>

                <!-- Hover Grid (Follows Mouse) -->
                <div class="absolute inset-0 pointer-events-none opacity-0 group-hover/section:opacity-100 transition-opacity duration-700" style="background-image: linear-gradient(to right, rgba(255,51,68, 0.25) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,51,68, 0.25) 1px, transparent 1px); background-size: 48px 48px; -webkit-mask-image: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), black, transparent 80%); mask-image: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), black, transparent 80%);"></div>
            </div>

            <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-[#FF3344] blur-[180px] opacity-[0.12] rounded-full"></div>
            <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] bg-[#FF3344] blur-[150px] opacity-[0.08] rounded-full"></div>
        </div>

        <div class="max-w-[1440px] mx-auto relative z-10">
            <div class="text-center mb-24">
                <p class="uppercase flex items-center justify-center gap-3 text-sm font-semibold text-[#FF3344] tracking-[0.3em] font-sans mb-5">
                     Client Voices
                </p>
                <h2 class="text-5xl md:text-6xl font-normal text-white tracking-tighter font-serif">
                    Let them do the <span class="italic text-[#FF3344]">talking.</span>
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
